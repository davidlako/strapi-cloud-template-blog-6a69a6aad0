{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "text"
    },
    "Description": {
      "type": "text"
    },
    "Content": {
      "type": "richtext"
    },
    "Thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Duration": {
      "type": "time"
    },
    "Category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::knowledge-base-category.knowledge-base-category"
    },
    "IsHighlighted": {
      "type": "boolean"
    }
  }
}
